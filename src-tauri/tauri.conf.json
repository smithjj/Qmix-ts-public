{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qmix",
  "version": "0.1.0",
  "identifier": "com.asphotonics.qmix",
  "build": {
    "beforeDevCommand": "npm run standalone",
    "beforeBuildCommand": "npm run build && npm run standalone",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Qmix",
        "url": "index.standalone.html",
        "width": 1280,
        "height": 900,
        "minWidth": 960,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Qmix phase-matching calculator",
    "longDescription": "Desktop wrapper for the Qmix nonlinear crystal phase-matching and refractive-index engine."
  }
}
